{
  "name": "nanohire-mini-project",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server",
    "contracts"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npx kill-port 4000 && npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "kill-port": "^2.0.1",
    "npm-run-all": "^4.1.5"
  }
}
